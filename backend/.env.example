# ============================================================
# Fleet Command System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is safe to commit.
#
# All variables are OPTIONAL — the system degrades gracefully.
# ============================================================

# ── Redis ──────────────────────────────────────────────────
# Connection string for Redis.
# Used for: alert persistence, distress rate-limiting, pub/sub broadcast.
# When unavailable the system runs in degraded mode (no persistence).
# Docker Compose sets this automatically to redis://redis:6379.
REDIS_URL=redis://localhost:6379

# ── AI — Google Gemini (recommended) ───────────────────────
# Enables intelligent distress signal NLP and the Fleet Advisor.
# Falls back to keyword extraction when absent.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── AI — OpenAI-compatible (alternative) ───────────────────
# Used if GEMINI_API_KEY is not set.
# Works with OpenAI, Azure OpenAI, Ollama, or any compatible proxy.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1/

# ── Fleet data ──────────────────────────────────────────────
# Path to fleet.json (ships, ports, navigable polygon, bounding box).
# Relative to the backend/ directory, or an absolute path.
# Default: ../fleet.json (project root)
# FLEET_JSON=/absolute/path/to/fleet.json

# ── Backend server ──────────────────────────────────────────
# Port the Node.js backend listens on.
# Docker Compose maps this to host port 8000.
# PORT=8000

# ── Frontend (Vite build-time) ──────────────────────────────
# Mapbox GL JS public access token.
# A hardcoded demo token is used as fallback (rate-limited).
# Get your own free token at: https://mapbox.com
VITE_MAPBOX_TOKEN=
